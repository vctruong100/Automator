if (!isEcoaMeasurementCollectionMessage(message)) {
    logger('Not an eCOA measurement collection message, skipping');
    return false;
}

// Condition helpers
var conditions = [];

// Adds a clinical condition to the conditions array if it does not already exist (prevents duplicates).
function addCondition(oid, name) {
    var exists = false;

    for (var i = 0; i < conditions.length; i++) {
        if (conditions[i].conditionOID === oid) {
            exists = true;
            break;
        }
    }

    if (!exists) {
        conditions.push({
            conditionOID: oid,
            conditionName: name
        });
    }
}

// Retrieves an item data object from the message by its parameter name.
function parameter(name) {
    for (var i = 0; i < message.itemDataInfo.length; i++) {
        var itemData = message.itemDataInfo[i];

        if (itemData.parameterName === name) {
            return itemData;
        }
    }
    return null;
}

// Evaluations
var systolic = parameter('Systolic');
if (systolic && systolic.value < 80) {
    addCondition('LS1', 'Low systolic');
}

var diastolic = parameter('Diastolic');
if (diastolic && diastolic.value < 50) {
    addCondition('LD1', 'Low diastolic');
}

if (conditions.length === 0) {
    logger('No conditions found');
    return false;
}

ctx.conditions = conditions;
return true;

